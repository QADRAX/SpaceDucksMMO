// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Asset {
  id          String         @id @default(uuid())
  key         String         @unique
  displayName String
  type        String // "texture" | "sprite_sheet" | "audio" | "map" | "prefab" | "shader" | "script" | "other"
  category    String
  tags        String // JSON array stored as string
  thumbnail   String? // Relative path to thumbnail image
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  isArchived  Boolean        @default(false)
  versions    AssetVersion[]

  @@index([key])
  @@index([type])
  @@index([category])
  @@index([isArchived])
}

model AssetVersion {
  id        String       @id @default(uuid())
  assetId   String
  asset     Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  version   String
  status    String       @default("draft") // "draft" | "published" | "deprecated"
  isDefault Boolean      @default(false)
  notes     String?
  createdAt DateTime     @default(now())
  files     AssetFile[]

  @@unique([assetId, version])
  @@index([assetId])
  @@index([status])
  @@index([isDefault])
}

model AssetFile {
  id             String       @id @default(uuid())
  assetVersionId String
  assetVersion   AssetVersion @relation(fields: [assetVersionId], references: [id], onDelete: Cascade)
  fileName       String
  relativePath   String?
  contentType    String
  size           Int
  hash           String
  mapType        String?      // For materials: "albedo" | "normal" | "roughness" | "metallic" | "ao" | "height" | "emission"
  createdAt      DateTime     @default(now())

  @@index([assetVersionId])
  @@index([mapType])
}
