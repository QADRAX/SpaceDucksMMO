// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE: The old Asset/AssetVersion/AssetFile models were intentionally removed.
// Web Core now models engine-facing Resources (versioned) and FileAssets (single file).

model FileAsset {
  id          String   @id @default(uuid())
  fileName    String
  contentType String
  size        Int
  sha256      String
  storagePath String
  createdAt   DateTime @default(now())

  bindings ResourceBinding[]

  @@index([sha256])
}

model Resource {
  id          String   @id @default(uuid())
  key         String   @unique
  displayName String
  kind        String   // e.g. "material"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isArchived  Boolean  @default(false)

  versions ResourceVersion[]

  @@index([key])
  @@index([kind])
  @@index([isArchived])
}

model ResourceVersion {
  id            String   @id @default(uuid())
  resourceId    String
  resource      Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  version       Int
  status        String   @default("draft") // "draft" | "published" | "deprecated"
  isDefault     Boolean  @default(false)
  componentType String   // e.g. "basicMaterial" | "lambertMaterial" | "phongMaterial" | "standardMaterial"
  // SQLite doesn't support Prisma's Json type; store stringified JSON.
  componentData String   @default("{}")
  createdAt     DateTime @default(now())

  bindings ResourceBinding[]

  @@unique([resourceId, version])
  @@index([resourceId])
  @@index([status])
  @@index([isDefault])
  @@index([componentType])
}

model ResourceBinding {
  id                String         @id @default(uuid())
  resourceVersionId String
  resourceVersion   ResourceVersion @relation(fields: [resourceVersionId], references: [id], onDelete: Cascade)
  slot              String
  fileAssetId       String
  fileAsset         FileAsset      @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  createdAt         DateTime       @default(now())

  @@unique([resourceVersionId, slot])
  @@index([resourceVersionId])
  @@index([fileAssetId])
  @@index([slot])
}
