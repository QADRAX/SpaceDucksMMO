{
  "name": "@duckengine/scripting-lua",
  "version": "0.1.0",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build:scripts": "ts-node --project tsconfig.json scripts/generate-scripts.ts",
    "prebuild": "pnpm run generate:component-types",
    "generate:component-types": "npx tsx scripts/generate-component-types.ts",
    "build": "npm run build:scripts && tsc -b tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && node --experimental-vm-modules ../../node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "@duckengine/core-v2": "^0.1.0",
    "wasmoon": "^1.16.0"
  }
}
