{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": "src",
    "paths": {
      "@client/*": ["*"]
    },
    "types": ["jest", "node"]
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../core" }, { "path": "../ecs" }]
}
