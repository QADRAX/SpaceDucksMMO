{
  "name": "@duckengine/scenes-yaml-v2",
  "version": "0.1.0",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run generate:scene-schema && tsc -b tsconfig.json",
    "typecheck": "tsc --noEmit",
    "generate:scene-schema": "npx tsx scripts/generate-scene-schema.ts",
    "test": "npm run typecheck && node --experimental-vm-modules ../../../node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "@duckengine/core-v2": "^0.1.0",
    "ajv": "^8.17.1",
    "js-yaml": "^4.1.0"
  }
}
