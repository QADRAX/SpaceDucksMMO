{
  "name": "@duckengine/core-v2",
  "version": "0.1.0",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "test": "npm run typecheck && node --experimental-vm-modules ../../../node_modules/jest/bin/jest.js",
    "typecheck": "tsc --noEmit",
    "format": "npx prettier --write \"src/**/*.ts\"",
    "format:check": "npx prettier --check \"src/**/*.ts\"",
    "clean-imports": "node consolidateImports.mjs"
  },
  "dependencies": {}
}