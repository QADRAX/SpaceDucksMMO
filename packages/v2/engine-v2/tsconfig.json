{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "references": [
    { "path": "../core-v2" },
    { "path": "../physics-rapier" },
    { "path": "../rendering-three-webgpu-v2" },
    { "path": "../resource-coordinator-v2" },
    { "path": "../scripting-lua" }
  ],
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
