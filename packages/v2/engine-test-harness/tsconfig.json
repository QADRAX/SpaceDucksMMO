{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "references": [
    { "path": "../animation-runtime-v2" },
    { "path": "../core-v2" },
    { "path": "../diagnostic-v2" },
    { "path": "../input-browser-v2" },
    { "path": "../input-node-v2" },
    { "path": "../physics-rapier" },
    { "path": "../rendering-three-v2" },
    { "path": "../resource-coordinator-v2" },
    { "path": "../scenes-yaml-v2" },
    { "path": "../scripting-lua" }
  ],
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
