{
  "name": "@duckengine/physics-rapier",
  "version": "0.1.0",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build:test-scripts": "ts-node scripts/generate-test-scripts.ts",
    "build": "npm run build:test-scripts && tsc -b tsconfig.json",
    "test": "jest",
    "test:integration": "jest --testPathPatterns=integration",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "test:performance": "jest --testPathPatterns=performance --detectOpenHandles --forceExit",
    "test:stress": "jest --testNamePattern='Stress Tests' --detectOpenHandles --forceExit",
    "perf:analyze": "node scripts/analyze-perf.js",
    "perf:analyze:latest": "node scripts/analyze-perf.js --latest",
    "perf:compare": "node scripts/analyze-perf.js --compare"
  },
  "dependencies": {
    "@duckengine/core": "^0.1.0",
    "@dimforge/rapier3d-compat": "^0.14.0"
  }
}