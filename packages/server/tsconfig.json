{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": "src",
    "paths": {
      "@app/*": ["application/*"],
      "@infra/*": ["infrastructure/*"],
      "@config/*": ["config/*"],
      "@di/*": ["di/*"],
      "@server/*": ["server/*"]
    }
  },
  "include": ["src"]
}
