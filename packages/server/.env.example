# Configuración del servidor SpaceDucks
# Nota: este archivo es un ejemplo. Copia/renombra a .env para usar.

# Puerto en el que escucha el servidor (por defecto: 3000)
PORT=3000

# Velocidad de simulación: ticks por segundo (por defecto: 20)
TICK_RATE=20

# Ruta al archivo YAML de configuración de la galaxia.
# Ruta relativa se resuelve desde packages/server (cwd del proceso).
# Por defecto: config/galaxy.yaml
GALAXY_CONFIG_PATH=config/galaxy.yaml
