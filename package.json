{
  "name": "spaceducks-mmo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "canvas": "^3.2.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.5.0"
  },
  "scripts": {
    "build": "npm --workspaces run build",
    "build:duckengine:ecs": "npm --workspace @duckengine/ecs run build",
    "build:duckengine:core": "npm --workspace @duckengine/core run build",
    "build:duckengine:rendering-three": "npm --workspace @duckengine/rendering-three run build",
    "build:client": "npm --workspace @spaceducks/client run build",
    "dev:client": "npm --workspace @spaceducks/client run dev:all",
    "start:client": "npm --workspace @spaceducks/client run start",
    "clean": "node -e \"console.log('No-op clean')\""
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
